# XenoPilot Root Environment Variables
# Copy this file to .env before running docker-compose up

# Postgres Configuration
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=xeno_crm

# Redis Configuration (For Celery broker and result backend)
REDIS_HOST=redis
REDIS_PORT=6379

# OpenAI API Key (Required for AI Agents, Segment Parser, Campaign Generation, and Insights)
# Get your key from platform.openai.com
OPENAI_API_KEY=your_openai_api_key_here

# Frontend Configuration
# URL pointing to the FastAPI backend service
NEXT_PUBLIC_API_URL=http://localhost:8000
